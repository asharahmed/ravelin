<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <script>
        // Apply the saved (or OS-preferred) color theme before first paint to avoid a flash,
        // and expose a tiny helper the Blazor toggle calls. Bootstrap 5.3 reads data-bs-theme.
        (function () {
            try {
                var stored = localStorage.getItem('ravelin.theme');
                var theme = stored || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
                document.documentElement.setAttribute('data-bs-theme', theme);
            } catch (e) { }
            window.ravelinTheme = {
                get: function () { return document.documentElement.getAttribute('data-bs-theme') || 'light'; },
                set: function (t) {
                    document.documentElement.setAttribute('data-bs-theme', t);
                    try { localStorage.setItem('ravelin.theme', t); } catch (e) { }
                    return t;
                },
                toggle: function () {
                    return window.ravelinTheme.set(window.ravelinTheme.get() === 'dark' ? 'light' : 'dark');
                }
            };
            // Animated count-up for dashboard metrics (honours reduced-motion).
            window.ravelinCountUp = function (el, target, duration, decimals) {
                if (!el) return;
                target = Number(target) || 0; duration = duration || 1100; decimals = decimals || 0;
                if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
                    el.textContent = target.toFixed(decimals); return;
                }
                var start = null;
                function frame(t) {
                    if (start === null) start = t;
                    var p = Math.min((t - start) / duration, 1);
                    var eased = 1 - Math.pow(1 - p, 4); // ease-out-quart
                    el.textContent = (target * eased).toFixed(decimals);
                    if (p < 1) requestAnimationFrame(frame); else el.textContent = target.toFixed(decimals);
                }
                requestAnimationFrame(frame);
            };
        })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700&family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&display=swap" />
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["ledger.css"]" />
    <link rel="stylesheet" href="@Assets["Ravelin.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet @rendermode="@(new InteractiveWebAssemblyRenderMode(prerender: false))" />
</head>

<body>
    <Routes @rendermode="@(new InteractiveWebAssemblyRenderMode(prerender: false))" />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>
