<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <script>
        // Apply the saved (or OS-preferred) color theme before first paint to avoid a flash,
        // and expose a tiny helper the Blazor toggle calls. Bootstrap 5.3 reads data-bs-theme.
        (function () {
            try {
                var stored = localStorage.getItem('ravelin.theme');
                var theme = stored || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
                document.documentElement.setAttribute('data-bs-theme', theme);
            } catch (e) { }
            window.ravelinTheme = {
                get: function () { return document.documentElement.getAttribute('data-bs-theme') || 'light'; },
                set: function (t) {
                    document.documentElement.setAttribute('data-bs-theme', t);
                    try { localStorage.setItem('ravelin.theme', t); } catch (e) { }
                    return t;
                },
                toggle: function () {
                    return window.ravelinTheme.set(window.ravelinTheme.get() === 'dark' ? 'light' : 'dark');
                }
            };
            // Trigger a client-side file download (used for CSV export).
            window.ravelinDownload = function (filename, mime, content) {
                try {
                    var blob = new Blob([content], { type: mime || 'text/plain' });
                    var url = URL.createObjectURL(blob);
                    var a = document.createElement('a');
                    a.href = url; a.download = filename;
                    document.body.appendChild(a); a.click();
                    document.body.removeChild(a);
                    setTimeout(function () { URL.revokeObjectURL(url); }, 0);
                } catch (e) { console.error('download failed', e); }
            };
            // Copy text to the clipboard (used for API keys + pipeline snippets).
            window.ravelinCopy = function (text) {
                try {
                    if (navigator.clipboard && navigator.clipboard.writeText) {
                        navigator.clipboard.writeText(text); return true;
                    }
                } catch (e) { }
                try {
                    var ta = document.createElement('textarea');
                    ta.value = text; ta.style.position = 'fixed'; ta.style.opacity = '0';
                    document.body.appendChild(ta); ta.focus(); ta.select();
                    document.execCommand('copy'); document.body.removeChild(ta); return true;
                } catch (e) { return false; }
            };
            // Open the browser print dialog (compliance report -> Save as PDF).
            window.ravelinPrint = function () { try { window.print(); } catch (e) { } };
            // Animated count-up for dashboard metrics (honours reduced-motion).
            window.ravelinCountUp = function (el, target, duration, decimals) {
                if (!el) return;
                target = Number(target) || 0; duration = duration || 1100; decimals = decimals || 0;
                if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
                    el.textContent = target.toFixed(decimals); return;
                }
                var start = null;
                function frame(t) {
                    if (start === null) start = t;
                    var p = Math.min((t - start) / duration, 1);
                    var eased = 1 - Math.pow(1 - p, 4); // ease-out-quart
                    el.textContent = (target * eased).toFixed(decimals);
                    if (p < 1) requestAnimationFrame(frame); else el.textContent = target.toFixed(decimals);
                }
                requestAnimationFrame(frame);
            };
            var prefersReduce = function () { return window.matchMedia('(prefers-reduced-motion: reduce)').matches; };
            // Count any [data-count] numbers inside a freshly-revealed element.
            function countWithin(scope) {
                if (!scope.querySelectorAll) return;
                scope.querySelectorAll('[data-count]').forEach(function (n) {
                    if (n.dataset.counted) return; n.dataset.counted = '1';
                    window.ravelinCountUp(n, parseFloat(n.dataset.count) || 0, 1100, parseInt(n.dataset.decimals) || 0);
                });
            }
            // Scroll-reveal: fade/slide elements in as they enter the viewport (once).
            window.ravelinReveal = function () {
                var els = document.querySelectorAll('.reveal:not(.in)');
                if (prefersReduce() || !('IntersectionObserver' in window)) {
                    els.forEach(function (e) { e.classList.add('in'); countWithin(e); });
                    return;
                }
                var io = new IntersectionObserver(function (entries) {
                    entries.forEach(function (en) {
                        if (en.isIntersecting) { en.target.classList.add('in'); countWithin(en.target); io.unobserve(en.target); }
                    });
                }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
                els.forEach(function (e) { io.observe(e); });
            };
            // Lightweight scroll parallax for [data-parallax] (speed factor, viewport-centred).
            window.ravelinParallax = function () {
                if (prefersReduce()) return;
                var els = Array.prototype.map.call(document.querySelectorAll('[data-parallax]'), function (e) {
                    return { el: e, s: parseFloat(e.dataset.parallax) || 0 };
                });
                if (!els.length) return;
                var vh = window.innerHeight, ticking = false;
                function update() {
                    var mid = window.scrollY + vh / 2;
                    els.forEach(function (o) {
                        var r = o.el.getBoundingClientRect();
                        var center = r.top + window.scrollY + r.height / 2;
                        o.el.style.transform = 'translate3d(0,' + ((center - mid) * o.s).toFixed(1) + 'px,0)';
                    });
                    ticking = false;
                }
                function onScroll() { if (!ticking) { ticking = true; requestAnimationFrame(update); } }
                window.addEventListener('scroll', onScroll, { passive: true });
                window.addEventListener('resize', function () { vh = window.innerHeight; onScroll(); }, { passive: true });
                update();
            };
            // Subtle pointer tilt for [data-tilt] cards (mouse only).
            window.ravelinTilt = function () {
                if (prefersReduce()) return;
                document.querySelectorAll('[data-tilt]').forEach(function (card) {
                    if (card.dataset.tiltBound) return; card.dataset.tiltBound = '1';
                    card.addEventListener('pointermove', function (e) {
                        if (e.pointerType === 'touch') return;
                        var r = card.getBoundingClientRect();
                        var px = (e.clientX - r.left) / r.width - 0.5, py = (e.clientY - r.top) / r.height - 0.5;
                        card.style.transform = 'perspective(1500px) rotateX(' + (-py * 2.3).toFixed(2) + 'deg) rotateY(' + (px * 3).toFixed(2) + 'deg)';
                    });
                    card.addEventListener('pointerleave', function () { card.style.transform = ''; });
                });
            };
        })();
    </script>
    <link rel="preload" as="font" type="font/woff2" href="fonts/zilla-slab-600.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="fonts/hanken-grotesk-400.woff2" crossorigin />
