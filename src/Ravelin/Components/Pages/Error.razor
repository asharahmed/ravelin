@page "/Error"
@using System.Diagnostics

<PageTitle>Error — Ravelin</PageTitle>

<div class="srv-error">
    <div class="srv-eyebrow">Error</div>
    <h1 class="srv-title">Something went wrong on our end.</h1>
    <p class="srv-lead">
        The request couldn't be completed. Try again in a moment.
    </p>
    @if (ShowRequestId)
    {
        <p class="srv-ref">Reference <code>@RequestId</code></p>
    }
    <a class="srv-btn" href="/">Back to Ravelin</a>
</div>

<style>
    .srv-error {
        max-width: 46ch;
        margin: clamp(3rem, 12vh, 7rem) auto;
        padding: 0 1.5rem;
        font-family: var(--font-body, system-ui, sans-serif);
        color: var(--ink, #222);
    }
    .srv-eyebrow {
        font-size: 0.72rem; font-weight: 600; letter-spacing: 0.16em;
        text-transform: uppercase; color: var(--ink-faint, #888);
    }
    .srv-title {
        font-family: var(--font-display, Georgia, serif);
        font-weight: 600; letter-spacing: -0.015em; line-height: 1.05;
        font-size: clamp(1.7rem, 4.5vw, 2.6rem); margin: 0.5rem 0 0.9rem;
    }
    .srv-lead { color: var(--ink-soft, #555); line-height: 1.6; margin: 0 0 1rem; }
    .srv-ref { font-size: 0.85rem; color: var(--ink-faint, #888); margin: 0 0 1.8rem; }
    .srv-ref code { font-size: 0.85em; }
    .srv-btn {
        display: inline-block; text-decoration: none; font-weight: 600;
        background: var(--brand, #7c2218); color: #fdf6f1;
        padding: 0.65rem 1.4rem; border-radius: var(--radius-sm, 9px);
    }
</style>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
