@page "/projects/{Key}"
@attribute [Authorize]
@inject HttpClient Http
@inject NavigationManager Nav
@inject ToastService Toasts
@inject IJSRuntime JS

<PageTitle>@(project?.Name ?? Key) — Ravelin</PageTitle>

<a class="back-link" href="dashboard"><span class="back-arrow" aria-hidden="true">←</span> Posture</a>

<header class="pd-head ledger-rise">
    <div>
        <div class="ledger-eyebrow">Project</div>
        <h1 class="ledger-display pd-title">@(project?.Name ?? Key)</h1>
        <code class="pd-key">@Key</code>
    </div>
    @if (summary is not null)
    {
        <div class="ledger-panel pd-gauge">
            <RadialGauge Percent="summary.Value.compliance" Label="within SLA" />
        </div>
    }
</header>

@if (loading)
{
    <div class="pd-skeleton" aria-hidden="true">
        <div class="pd-stats">
            @for (var i = 0; i < 4; i++)
            {
                <div class="ledger-panel sk-stat">
                    <span class="skeleton sk-line sk-sm"></span>
                    <span class="skeleton sk-line sk-xl"></span>
                </div>
            }
        </div>
        <div class="ledger-panel sk-table">
            @for (var i = 0; i < 5; i++)
            {
                <span class="skeleton sk-row"></span>
            }
        </div>
    </div>
    <span class="pd-sr" role="status">Loading findings…</span>
}
else if (error is not null)
{
    <div class="ledger-panel pd-error">@error</div>
}
else
{
    <section class="ledger-panel pd-stats reveal">
        <StatTile Label="Open" Value="summary!.Value.open" />
        <StatTile Label="Breached" Value="summary.Value.breached" AccentClass="accent-breached" />
        <StatTile Label="Due soon" Value="summary.Value.dueSoon" AccentClass="accent-duesoon" />
        <StatTile Label="Resolved" Value="summary.Value.resolved" AccentClass="accent-ontrack" />
    </section>

    <section class="ledger-panel pd-findings reveal">
        <div class="card-head">
            <h2 class="ledger-display card-title">Findings</h2>
            <div class="pd-filter">
                @foreach (var f in filters)
                {
                    <button class="pd-chip @(activeFilter == f ? "is-active" : "")" @onclick="() => activeFilter = f">
                        @f<span class="pd-chip-count">@Count(f)</span>
                    </button>
                }
            </div>
        </div>

        <div class="pd-toolbar">
            <div class="pd-search">
                <svg class="pd-search-icon" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <circle cx="11" cy="11" r="7" /><path d="m20 20-3.5-3.5" stroke-linecap="round" />
                </svg>
                <input class="pd-search-input" type="search" placeholder="Search findings, CVE, package…"
                       @bind="searchText" @bind:event="oninput" aria-label="Search findings" />
                @if (!string.IsNullOrEmpty(searchText))
                {
                    <button class="pd-search-clear" @onclick="@(() => searchText = "")" aria-label="Clear search">&times;</button>
                }
            </div>
            <button class="pd-export" @onclick="ExportCsv" disabled="@(!Visible.Any())" title="Download the current view as CSV">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M12 3v12m0 0 4-4m-4 4-4-4M4 21h16" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                Export CSV
            </button>
        </div>
        <hr class="ledger-rule" />

        @if (!Visible.Any())
        {
            <div class="pd-empty ledger-rise">
                <span class="pd-empty-mark" aria-hidden="true"></span>
                <p class="pd-empty-text">
                    @if (!string.IsNullOrWhiteSpace(searchText))
                    {
                        <span>No findings match “@searchText”.</span>
                    }
                    else if (activeFilter == "Breached")
                    {
                        <span>Nothing breached. Every open finding is still within its SLA window.</span>
                    }
                    else if (activeFilter == "Open")
                    {
                        <span>No open findings. This project is clear.</span>
                    }
                    else
                    {
                        <span>No @(activeFilter == "All" ? "" : activeFilter.ToLowerInvariant() + " ")findings to show.</span>
                    }
                </p>
            </div>
        }
        else
        {
            <table class="find-table">
                <thead>
                    <tr>
                        <th><button class="find-sort @SortCls("Severity")" @onclick="@(() => SortBy("Severity"))">Severity @SortArrow("Severity")</button></th>
                        <th>Vulnerability</th>
                        <th><button class="find-sort @SortCls("Package")" @onclick="@(() => SortBy("Package"))">Package @SortArrow("Package")</button></th>
                        <th><button class="find-sort @SortCls("Status")" @onclick="@(() => SortBy("Status"))">Status @SortArrow("Status")</button></th>
                        <th><button class="find-sort @SortCls("SLA")" @onclick="@(() => SortBy("SLA"))">SLA @SortArrow("SLA")</button></th>
                        <AuthorizeView Roles="@TriageRoles" Context="auth"><Authorized><th></th></Authorized></AuthorizeView>
                    </tr>
                </thead>
                <tbody data-reveal-stagger>
                    @foreach (var f in Visible)
                    {
                        <tr class="find-row reveal">
                            <td><span class="chip @SevClass(f.Severity)">@f.Severity</span></td>
                            <td>
                                <div class="find-title">@f.Title</div>
                                <code class="find-vuln">@f.VulnerabilityId</code>
                            </td>
                            <td><span class="find-pkg">@f.PackageName</span> <span class="find-ver">@f.PackageVersion</span></td>
                            <td><span class="find-status">@Humanize(f.Status)</span></td>
                            <td>@SlaCell(f)</td>
                            <AuthorizeView Roles="@TriageRoles" Context="auth">
                                <Authorized>
                                    <td class="find-action">
                                        <button class="pd-triage-btn" @onclick="() => OpenTriage(f)">Triage</button>
                                    </td>
                                </Authorized>
                            </AuthorizeView>
                        </tr>
                        @if (editingId == f.Id)
                        {
                            <tr class="triage-row">
                                <td colspan="6">
                                    <div class="triage-panel">
                                        <div class="triage-fields">
                                            <label>
                                                <span class="ledger-eyebrow">New status</span>
                                                <select @bind="triageStatus">
                                                    <option value="Open">Open (reopen)</option>
                                                    <option value="Resolved">Resolved</option>
                                                    <option value="FalsePositive">False positive</option>
                                                    <option value="AcceptedRisk">Accepted risk</option>
                                                </select>
                                            </label>
                                            <label class="triage-note">
                                                <span class="ledger-eyebrow">Justification @(NoteRequired ? "(required)" : "(optional)")</span>
                                                <input @bind="triageNote" placeholder="Why this decision?" />
                                            </label>
                                        </div>
                                        <div class="triage-actions">
                                            @if (triageError is not null)
                                            {
                                                <span class="triage-err">@triageError</span>
                                            }
                                            <button class="btn-ghost" @onclick="CancelTriage" disabled="@saving">Cancel</button>
                                            <button class="btn-seal" @onclick="() => SaveTriage(f)" disabled="@saving">@(saving ? "Saving…" : "Apply")</button>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        }
    </section>
}

@code {
    [Parameter] public string Key { get; set; } = "";

    private const string TriageRoles = $"{RavelinRoles.Admin},{RavelinRoles.Analyst}";
    private static readonly string[] filters = ["All", "Open", "Breached", "Resolved", "Suppressed"];

    private ProjectDto? project;
    private List<FindingDto> findings = [];
    private bool loading = true;
    private string? error;
    private string activeFilter = "Open";
    private string searchText = "";
    private string sortColumn = "Severity";
    private bool sortAsc = false;

    private Guid? editingId;
    private string triageStatus = "Resolved";
    private string triageNote = "";
    private string? triageError;
    private bool saving;

    private bool NoteRequired => triageStatus is "FalsePositive" or "AcceptedRisk";

    private (int open, int breached, int dueSoon, int resolved, double compliance)? summary;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        loading = true;
        error = null;
        try
        {
            var projects = await Http.GetFromJsonAsync<List<ProjectDto>>("api/projects") ?? [];
            project = projects.FirstOrDefault(p => p.Key == Key);
            findings = await Http.GetFromJsonAsync<List<FindingDto>>($"api/projects/{Key}/findings") ?? [];
            ComputeSummary();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            loading = false;
        }
    }

    private void ComputeSummary()
    {
        var open = findings.Count(f => f.Status == "Open");
        var breached = findings.Count(f => f.SlaState == "Breached");
        var dueSoon = findings.Count(f => f.SlaState == "DueSoon");
        var resolved = findings.Count(f => f.Status == "Resolved");
        var compliance = open == 0 ? 100 : Math.Round((double)(open - breached) / open * 100, 1);
        summary = (open, breached, dueSoon, resolved, compliance);
    }

    private IEnumerable<FindingDto> Filtered(string filter) => filter switch
    {
        "Open" => findings.Where(f => f.Status == "Open"),
        "Breached" => findings.Where(f => f.SlaState == "Breached"),
        "Resolved" => findings.Where(f => f.Status == "Resolved"),
        "Suppressed" => findings.Where(f => f.Status is "FalsePositive" or "AcceptedRisk"),
        _ => findings,
    };

    private IEnumerable<FindingDto> Visible => Sort(Search(Filtered(activeFilter)));

    private int Count(string filter) => Filtered(filter).Count();

    private IEnumerable<FindingDto> Search(IEnumerable<FindingDto> q)
    {
        if (string.IsNullOrWhiteSpace(searchText)) return q;
        var s = searchText.Trim();
        return q.Where(f =>
            Has(f.Title, s) || Has(f.VulnerabilityId, s) ||
            Has(f.PackageName, s) || Has(f.PackageVersion, s) || Has(f.Severity, s));
    }

    private static bool Has(string? v, string s) =>
        v is not null && v.Contains(s, StringComparison.OrdinalIgnoreCase);

    private static int SevRank(string s) => s switch
    {
        "Critical" => 4, "High" => 3, "Medium" => 2, "Low" => 1, _ => 0,
    };

    private IEnumerable<FindingDto> Sort(IEnumerable<FindingDto> q)
    {
        Func<FindingDto, IComparable> key = sortColumn switch
        {
            "Package" => f => f.PackageName ?? "",
            "Status" => f => f.Status ?? "",
            "SLA" => f => f.DaysToSla ?? int.MaxValue,
            _ => f => SevRank(f.Severity),
        };
        return sortAsc ? q.OrderBy(key) : q.OrderByDescending(key);
    }

    private void SortBy(string col)
    {
        if (sortColumn == col) { sortAsc = !sortAsc; }
        else { sortColumn = col; sortAsc = col is "Package" or "Status"; }
    }

    private string SortCls(string col) => sortColumn == col ? "is-sorted" : "";
    private string SortArrow(string col) => sortColumn != col ? "" : sortAsc ? "↑" : "↓";

    private async Task ExportCsv()
    {
        var rows = Visible.ToList();
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("Severity,Vulnerability,Title,Package,Version,Status,SLA State,Days To SLA");
        foreach (var f in rows)
        {
            sb.AppendLine(Ravelin.Shared.Csv.Row(
                f.Severity, f.VulnerabilityId, f.Title,
                f.PackageName, f.PackageVersion, Humanize(f.Status),
                f.SlaState, f.DaysToSla?.ToString()));
        }
        var name = $"ravelin-{Key}-findings-{DateTime.Now:yyyyMMdd}.csv";
        await JS.InvokeVoidAsync("ravelinDownload", name, "text/csv", sb.ToString());
        Toasts.Success($"Exported {rows.Count} finding{(rows.Count == 1 ? "" : "s")} to CSV.");
    }

    private void OpenTriage(FindingDto f)
    {
        editingId = f.Id;
        triageStatus = f.Status == "Open" ? "Resolved" : "Open";
        triageNote = "";
        triageError = null;
    }

    private void CancelTriage()
    {
        editingId = null;
        triageError = null;
    }

    private async Task SaveTriage(FindingDto f)
    {
        triageError = null;
        if (NoteRequired && string.IsNullOrWhiteSpace(triageNote))
        {
            triageError = "A justification is required.";
            return;
        }
        saving = true;
        try
        {
            var resp = await Http.PostAsJsonAsync($"api/projects/{Key}/findings/{f.Id}/triage",
                new TriageFindingRequest { Status = triageStatus, Note = string.IsNullOrWhiteSpace(triageNote) ? null : triageNote });
            if (!resp.IsSuccessStatusCode)
            {
                triageError = await ApiErrors.ReadMessageAsync(resp, "Could not apply the triage.");
                return;
            }
            editingId = null;
            Toasts.Success($"“{Truncate(f.Title, 40)}” marked {Humanize(triageStatus).ToLowerInvariant()}.");
            await Load();
        }
        catch (Exception ex)
        {
            triageError = ex.Message;
        }
        finally
        {
            saving = false;
        }
    }

    private static string SevClass(string sev) => "sev-" + sev.ToLowerInvariant();

    private static string Truncate(string s, int max) =>
        string.IsNullOrEmpty(s) || s.Length <= max ? s : s[..(max - 1)].TrimEnd() + "…";

    private static string Humanize(string status) => status switch
    {
        "FalsePositive" => "False positive",
        "AcceptedRisk" => "Accepted risk",
        _ => status,
    };

    private RenderFragment SlaCell(FindingDto f) => builder =>
    {
        if (f.SlaState == "NotApplicable")
        {
            builder.OpenElement(0, "span");
            builder.AddAttribute(1, "class", "sla-na");
            builder.AddContent(2, "—");
            builder.CloseElement();
            return;
        }
        var cls = "chip sla-" + f.SlaState.ToLowerInvariant();
        var text = f.SlaState switch
        {
            "Breached" => f.DaysToSla is int d ? $"{Math.Abs(d)}d over" : "breached",
            "DueSoon" => f.DaysToSla is int d ? $"{d}d left" : "due soon",
            _ => f.DaysToSla is int d ? $"{d}d left" : "on track",
        };
        builder.OpenElement(0, "span");
        builder.AddAttribute(1, "class", cls);
        builder.AddContent(2, text);
        builder.CloseElement();
    };
}
