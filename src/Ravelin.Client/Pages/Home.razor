@page "/"
@inject HttpClient Http
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthState

<PageTitle>Ravelin — vulnerability SLA &amp; compliance tracker</PageTitle>

<div class="landing">
    <div class="landing-inner ledger-rise">
        <div class="ledger-eyebrow">Vulnerability SLA &amp; compliance</div>
        <h1 class="ledger-display landing-title">Hold the line on<br />security debt.</h1>
        <p class="landing-lead">
            Ravelin turns dependency-scan results into an accountability layer: severity-based
            remediation SLAs, posture trends over time, and audit-ready compliance — so nothing
            slips past its deadline unnoticed.
        </p>

        <div class="landing-cta">
            <a class="cta-primary" href="login">Sign in</a>
            <span class="cta-status">
                <span class="status-dot @(apiUp ? "up" : "down")"></span>
                @(apiUp ? "API operational" : "checking…")
            </span>
        </div>

        <dl class="landing-points">
            <div>
                <dt class="ledger-display">SLAs that bite</dt>
                <dd>Every finding inherits a severity-based deadline. Breaches surface immediately.</dd>
            </div>
            <div>
                <dt class="ledger-display">Posture over time</dt>
                <dd>Opened-vs-resolved trends and compliance %, per project and across the org.</dd>
            </div>
            <div>
                <dt class="ledger-display">Triage with a trail</dt>
                <dd>False-positive and accepted-risk decisions require a justification — audit-ready.</dd>
            </div>
        </dl>
    </div>
</div>

@code {
    private bool apiUp;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var info = await Http.GetFromJsonAsync<ApiInfo>("api/info");
            apiUp = info is not null;
        }
        catch { apiUp = false; }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var auth = await AuthState.GetAuthenticationStateAsync();
            if (auth.User.Identity?.IsAuthenticated == true)
            {
                Nav.NavigateTo("dashboard", replace: true);
            }
        }
    }
}
