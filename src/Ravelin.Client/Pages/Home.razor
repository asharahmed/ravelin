@page "/"
@layout PublicLayout
@inject HttpClient Http
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthState

<PageTitle>Ravelin — vulnerability SLA &amp; compliance tracker</PageTitle>

<div class="landing">
    <div class="landing-top">
        <div class="landing-inner ledger-rise">
            <div class="ledger-eyebrow">Vulnerability SLA &amp; compliance</div>
            <h1 class="ledger-display landing-title">Every vulnerability gets a deadline.</h1>
            <p class="landing-lead">
                Ravelin takes the dependency scans your CI already runs and holds each finding to a
                remediation SLA based on its severity. You see what's overdue, where compliance is
                slipping, and how it's trending.
            </p>

            <div class="landing-cta">
                <a class="cta-primary" href="login">Sign in</a>
                <span class="cta-status">
                    <span class="status-dot @(apiUp ? "up" : "down")"></span>
                    @(apiUp ? "API operational" : "checking…")
                </span>
            </div>
        </div>

        <div class="landing-viz ledger-rise" style="animation-delay:.12s">
            <Globe />
        </div>
    </div>

    <dl class="landing-points">
            <div>
                <dt class="ledger-display">Severity-based SLAs</dt>
                <dd>Each finding inherits a remediation deadline from its severity. Breaches surface the moment they happen.</dd>
            </div>
            <div>
                <dt class="ledger-display">Trends over time</dt>
                <dd>Opened versus resolved and compliance percentage, per project and across every project.</dd>
            </div>
            <div>
                <dt class="ledger-display">Auditable triage</dt>
                <dd>Marking a finding a false positive or accepted risk requires a written justification.</dd>
            </div>
        </dl>
</div>

@code {
    private bool apiUp;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var info = await Http.GetFromJsonAsync<ApiInfo>("api/info");
            apiUp = info is not null;
        }
        catch { apiUp = false; }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var auth = await AuthState.GetAuthenticationStateAsync();
            if (auth.User.Identity?.IsAuthenticated == true)
            {
                Nav.NavigateTo("dashboard", replace: true);
            }
        }
    }
}
