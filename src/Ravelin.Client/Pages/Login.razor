@page "/login"
@layout PublicLayout
@using System.ComponentModel.DataAnnotations
@inject AuthService Auth
@inject NavigationManager Nav

<PageTitle>Sign in — Ravelin</PageTitle>

<div class="auth-wrap">
    <div class="auth-inner ledger-rise">
        <div class="ledger-eyebrow">Ravelin</div>
        <h1 class="ledger-display auth-title">Sign in.</h1>
        <p class="auth-sub">Security posture, open findings, and SLA compliance across every project.</p>

        <EditForm Model="model" OnValidSubmit="SubmitAsync">
            <DataAnnotationsValidator />

            @if (error is not null)
            {
                <div class="auth-error" role="alert">
                    <span class="auth-error-dot" aria-hidden="true"></span>
                    <span>@error</span>
                </div>
            }

            <div class="mb-3">
                <label class="form-label" for="email">Email</label>
                <InputText id="email" class="form-control" @bind-Value="model.Email"
                           autocomplete="username" />
                <ValidationMessage For="() => model.Email" />
            </div>

            <div class="mb-3">
                <label class="form-label" for="password">Password</label>
                <InputText id="password" type="password" class="form-control"
                           @bind-Value="model.Password" autocomplete="current-password" />
                <ValidationMessage For="() => model.Password" />
            </div>

            <button class="auth-submit" type="submit" disabled="@busy">
                @(busy ? "Signing in…" : "Sign in")
            </button>
        </EditForm>

        <p class="auth-alt">New to Ravelin? <a href="signup">Create an account</a></p>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private readonly LoginModel model = new();
    private string? error;
    private bool busy;

    private async Task SubmitAsync()
    {
        busy = true;
        error = null;

        error = await Auth.LoginAsync(new LoginRequest
        {
            Email = model.Email,
            Password = model.Password,
        });

        busy = false;

        if (error is null)
        {
            // Only honor a same-site relative returnUrl. Without this check, a crafted link like
            // /login?returnUrl=https://evil.example would bounce the freshly-authenticated user to
            // an attacker page that borrows this domain's trust (open redirect → phishing).
            Nav.NavigateTo(IsLocalReturnUrl(ReturnUrl) ? ReturnUrl! : "dashboard");
        }
    }

    // Accepts rooted ("/dashboard") and bare ("dashboard", "projects/foo") relative paths, which
    // is what RedirectToLogin produces; rejects absolute URLs, protocol-relative ("//evil"),
    // backslash tricks, and anything scheme-like ("https:evil", "javascript:...").
    private static bool IsLocalReturnUrl(string? url)
    {
        if (string.IsNullOrWhiteSpace(url)) return false;
        if (url.StartsWith("//") || url.StartsWith("/\\")) return false;
        if (url.StartsWith('\\')) return false;
        if (url.StartsWith('/')) return true;
        // Bare relative path is local only if it has no scheme separator.
        return !url.Contains(':');
    }

    private sealed class LoginModel
    {
        [Required, EmailAddress]
        public string Email { get; set; } = string.Empty;

        [Required]
        public string Password { get; set; } = string.Empty;
    }
}
