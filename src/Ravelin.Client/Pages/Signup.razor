@page "/signup"
@layout PublicLayout
@using System.ComponentModel.DataAnnotations
@inject AuthService Auth
@inject NavigationManager Nav

<PageTitle>Create account — Ravelin</PageTitle>

<div class="auth-wrap">
    <div class="auth-inner ledger-rise">
        <div class="ledger-eyebrow">Ravelin</div>
        <h1 class="ledger-display auth-title">Create your account.</h1>
        <p class="auth-sub">
            New accounts get read-only access to dashboards and compliance reports. Analyst and
            admin permissions are granted by an administrator.
        </p>

        <EditForm Model="model" OnValidSubmit="SubmitAsync">
            <DataAnnotationsValidator />

            @if (error is not null)
            {
                <div class="auth-error" role="alert">
                    <span class="auth-error-dot" aria-hidden="true"></span>
                    <span>@error</span>
                </div>
            }

            <div class="mb-3">
                <label class="form-label" for="email">Email</label>
                <InputText id="email" class="form-control" @bind-Value="model.Email"
                           autocomplete="username" />
                <ValidationMessage For="() => model.Email" />
            </div>

            <div class="mb-3">
                <label class="form-label" for="password">Password</label>
                <InputText id="password" type="password" class="form-control"
                           @bind-Value="model.Password" autocomplete="new-password" />
                <ValidationMessage For="() => model.Password" />
            </div>

            <button class="auth-submit" type="submit" disabled="@busy">
                @(busy ? "Creating account…" : "Create account")
            </button>
        </EditForm>

        <p class="auth-alt">Already have an account? <a href="login">Sign in</a></p>
    </div>
</div>

@code {
    private readonly RegisterModel model = new();
    private string? error;
    private bool busy;

    private async Task SubmitAsync()
    {
        busy = true;
        error = null;

        error = await Auth.RegisterAsync(new RegisterRequest
        {
            Email = model.Email,
            Password = model.Password,
        });

        busy = false;

        if (error is null)
        {
            Nav.NavigateTo("dashboard");
        }
    }

    private sealed class RegisterModel
    {
        [Required, EmailAddress]
        public string Email { get; set; } = string.Empty;

        [Required, MinLength(12, ErrorMessage = "Use at least 12 characters.")]
        public string Password { get; set; } = string.Empty;
    }
}
