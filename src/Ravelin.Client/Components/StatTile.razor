<div class="stat-tile @AccentClass">
    <div class="ledger-eyebrow">@Label</div>
    <div class="stat-value ledger-num">
        <span data-count="@Value.ToString(System.Globalization.CultureInfo.InvariantCulture)" data-decimals="@Decimals">@Value.ToString(Fmt)</span><span class="stat-suffix">@Suffix</span>
    </div>
    @if (!string.IsNullOrWhiteSpace(Caption))
    {
        <div class="stat-caption">@Caption</div>
    }
</div>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = "";
    [Parameter] public double Value { get; set; }
    [Parameter] public int Decimals { get; set; }
    [Parameter] public string Suffix { get; set; } = "";
    /// <summary>One of: accent-brand / accent-breached / accent-duesoon / accent-ontrack.</summary>
    [Parameter] public string? AccentClass { get; set; }
    [Parameter] public string? Caption { get; set; }

    private string Fmt => "F" + Decimals;
}
