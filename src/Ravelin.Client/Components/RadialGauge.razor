@inject IJSRuntime JS

@* A ledger balance, not a gauge: the compliant share settled in black ink,
   the remainder carried in red. *@
<div class="balance @LevelClass">
    <div class="balance-head">
        <div class="balance-figure led-figure"><span @ref="numRef">@Percent.ToString("F0")</span><span class="balance-pct">%</span></div>
        <div class="balance-label led-label">@Label</div>
    </div>
    <div class="balance-bar" role="img" aria-label="@Label @Percent.ToString("F0")%">
        <span class="balance-settled" style="--w:@Inv(Percent)%;"></span>
    </div>
    <div class="balance-foot">
        <span>Within SLA</span>
        <span>Breached</span>
    </div>
</div>

@code {
    [Parameter] public double Percent { get; set; }
    [Parameter] public string Label { get; set; } = "within SLA";

    private ElementReference numRef;

    private string LevelClass => Percent >= 90 ? "bal-good" : Percent >= 70 ? "bal-warn" : "bal-bad";

    private static string Inv(double v) => v.ToString(System.Globalization.CultureInfo.InvariantCulture);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("ravelinCountUp", numRef, Percent, 1100, 0);
        }
    }
}
