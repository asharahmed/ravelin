@* Integration marquee — tool glyphs from simple-icons (CC0). Ravelin ingests
   SCA results from these CI systems and scanners. Auto-scrolls; static + wrapped
   under prefers-reduced-motion (handled in CSS). *@
<div class="marq" role="img" aria-label="Works with GitHub, GitLab, Azure DevOps, Jenkins, CircleCI, Dependabot, Snyk, Trivy, OWASP Dependency-Check, SonarQube, Docker, Aqua, and AssemblyLine">
    <div class="marq-track">
        @foreach (var l in Logos)
        {
            <span class="marq-item" title="@l.Name">
                <svg viewBox="@l.ViewBox" width="30" height="30" fill="currentColor" aria-hidden="true">
                    @if (l.Inner is { } inner)
                    {
                        @((MarkupString)inner)
                    }
                    else
                    {
                        <path d="@l.Path" />
                    }
                </svg>
                <span class="marq-name">@l.Name</span>
            </span>
        }
        @* duplicate track for a seamless loop *@
        @foreach (var l in Logos)
        {
            <span class="marq-item" aria-hidden="true">
                <svg viewBox="@l.ViewBox" width="30" height="30" fill="currentColor">
                    @if (l.Inner is { } inner)
                    {
                        @((MarkupString)inner)
                    }
                    else
                    {
                        <path d="@l.Path" />
                    }
                </svg>
                <span class="marq-name">@l.Name</span>
            </span>
        }
    </div>
</div>

