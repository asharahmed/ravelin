@using System.Globalization
@using Ravelin.Shared.Contracts

<div class="trend">
    <div class="trend-legend">
        <span class="trend-key trend-key-opened">Opened</span>
        <span class="trend-key trend-key-resolved">Resolved</span>
    </div>

    @if (HasData)
    {
        @* Uniform scaling (no preserveAspectRatio="none"): geometry stays true — round
           markers, even gridlines — and the SVG scales responsively with its width. *@
        <svg viewBox="0 0 @F(W) @F(H)" class="trend-svg" role="img"
             aria-label="Findings opened versus resolved over the last @Points.Count weeks">
            @* horizontal gridlines + y-axis value labels (built as markup: Razor reserves <text>) *@
            @GridMarkup
            <line class="trend-baseline" x1="@F(PadL)" y1="@F(BaseY)" x2="@F(W - PadR)" y2="@F(BaseY)" />

            <path class="trend-area" d="@Area(p => p.Opened)" />
            <path class="trend-line trend-line-resolved" d="@Smooth(p => p.Resolved)" />
            <path class="trend-line trend-line-opened" d="@Smooth(p => p.Opened)" />

            @* per-week hover columns: guide + markers + native tooltip *@
            @for (var i = 0; i < Points.Count; i++)
            {
                var p = Points[i];
                var cx = X(i);
                <g class="trend-col">
                    <title>Week of @p.WeekStart.ToString("MMM d"): @p.Opened opened, @p.Resolved resolved</title>
                    <line class="trend-guide" x1="@F(cx)" y1="@F(PadT)" x2="@F(cx)" y2="@F(BaseY)" />
                    <circle class="trend-mark trend-mark-resolved" cx="@F(cx)" cy="@F(Y(p.Resolved))" r="3" />
                    <circle class="trend-mark trend-mark-opened" cx="@F(cx)" cy="@F(Y(p.Opened))" r="3" />
                    <rect class="trend-hit" x="@F(cx - ColW / 2)" y="0" width="@F(ColW)" height="@F(H)" />
                </g>
            }

            <circle class="trend-dot trend-dot-resolved" cx="@F(LastX)" cy="@F(Y(Points[^1].Resolved))" r="3.6" />
            <circle class="trend-dot trend-dot-opened" cx="@F(LastX)" cy="@F(Y(Points[^1].Opened))" r="3.6" />
        </svg>
        <div class="trend-axis">
            <span>@Points[0].WeekStart.ToString("MMM d")</span>
            <span>this week</span>
        </div>
    }
    else
    {
        <p class="trend-empty">No scan activity in this window yet.</p>
    }
</div>

@code {
    [Parameter] public IReadOnlyList<TrendPointDto> Points { get; set; } = [];

    private static readonly CultureInfo Inv = CultureInfo.InvariantCulture;
    private const double W = 600, H = 180, PadT = 16, PadB = 22, PadL = 26, PadR = 10;

    private static string F(double v) => v.ToString("0.#", Inv);

    private double ColW => Points.Count > 1 ? (W - PadL - PadR) / (Points.Count - 1) : W;
    private bool HasData => Points.Count >= 2 && Points.Any(p => p.Opened > 0 || p.Resolved > 0);

    // A "nice" axis maximum so the gridlines land on round numbers.
    private int NiceMax
    {
        get
        {
            var raw = Math.Max(1, Points.Max(p => Math.Max(p.Opened, p.Resolved)));
            if (raw <= 4) return raw;
            if (raw <= 10) return (int)(Math.Ceiling(raw / 2.0) * 2);
            return (int)(Math.Ceiling(raw / 5.0) * 5);
        }
    }

    private double BaseY => H - PadB;
    private double X(int i) => PadL + i * ((W - PadL - PadR) / (Points.Count - 1));
    private double Y(double v) => PadT + (1 - v / NiceMax) * (H - PadT - PadB);
    private double LastX => X(Points.Count - 1);

    private MarkupString GridMarkup
    {
        get
        {
            var max = NiceMax;
            var step = max <= 4 ? 1 : max <= 10 ? 2 : 5;
            var sb = new System.Text.StringBuilder();
            for (var v = 0; v <= max; v += step)
            {
                var gy = Y(v);
                // Styles are inline because these elements are injected as raw markup, which
                // Blazor's scoped CSS can't reach — so it falls back to black (invisible in dark).
                sb.Append($"<line class=\"trend-grid\" style=\"stroke:var(--line);stroke-width:1\" x1=\"{F(PadL)}\" y1=\"{F(gy)}\" x2=\"{F(W - PadR)}\" y2=\"{F(gy)}\"></line>");
                sb.Append($"<text class=\"trend-ylabel\" style=\"fill:var(--ink-faint);font-family:var(--font-mono);font-size:9px\" x=\"{F(PadL - 6)}\" y=\"{F(gy + 3)}\" text-anchor=\"end\">{v}</text>");
            }
            return new MarkupString(sb.ToString());
        }
    }

    // Smooth path via Catmull-Rom → cubic béziers, with control points clamped to the
    // plot band so the curve never overshoots below 0 or above the axis max.
    private string Smooth(Func<TrendPointDto, int> sel)
    {
        var pts = Points.Select((p, i) => (x: X(i), y: Y(sel(p)))).ToArray();
        if (pts.Length < 3)
            return "M" + string.Join(" L", pts.Select(p => $"{F(p.x)},{F(p.y)}"));

        double Clamp(double y) => Math.Clamp(y, PadT, BaseY);
        var sb = new System.Text.StringBuilder($"M{F(pts[0].x)},{F(pts[0].y)}");
        for (var i = 0; i < pts.Length - 1; i++)
        {
            var p0 = pts[Math.Max(i - 1, 0)];
            var p1 = pts[i];
            var p2 = pts[i + 1];
            var p3 = pts[Math.Min(i + 2, pts.Length - 1)];
            var c1x = p1.x + (p2.x - p0.x) / 6.0;
            var c1y = Clamp(p1.y + (p2.y - p0.y) / 6.0);
            var c2x = p2.x - (p3.x - p1.x) / 6.0;
            var c2y = Clamp(p2.y - (p3.y - p1.y) / 6.0);
            sb.Append($" C{F(c1x)},{F(c1y)} {F(c2x)},{F(c2y)} {F(p2.x)},{F(p2.y)}");
        }
        return sb.ToString();
    }

    private string Area(Func<TrendPointDto, int> sel) =>
        $"{Smooth(sel)} L{F(LastX)},{F(BaseY)} L{F(PadL)},{F(BaseY)} Z";
}
