<div class="led-line @ColorClass">
    <span class="led-tick" aria-hidden="true"></span>
    <span class="leader-label">@Label</span>
    <span class="leader-fill"></span>
    <span class="leader-value led-figure">@Value</span>
</div>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = "";
    [Parameter] public int Value { get; set; }
    [Parameter] public int Max { get; set; } = 1;
    /// <summary>A sev-* or sla-* class (sets --chip-color).</summary>
    [Parameter] public string ColorClass { get; set; } = "";
}
