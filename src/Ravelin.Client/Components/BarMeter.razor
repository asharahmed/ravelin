<div class="bar-row">
    <span class="bar-label">@Label</span>
    <span class="bar-track">
        <span class="bar-fill @ColorClass" style="--w:@Width.ToString(System.Globalization.CultureInfo.InvariantCulture)%;"></span>
    </span>
    <span class="bar-value ledger-num">@Value</span>
</div>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = "";
    [Parameter] public int Value { get; set; }
    [Parameter] public int Max { get; set; } = 1;
    /// <summary>A sev-* or sla-* class (sets --chip-color).</summary>
    [Parameter] public string ColorClass { get; set; } = "";

    private double Width => Max <= 0 ? 0 : Math.Max(Value > 0 ? 4 : 0, (double)Value / Max * 100);
}
