@* Shared brand lockup: bastion-salient mark + bespoke "RAVELIN" wordmark. *@
<a class="brand" href="@Href">
    <span class="brand-mark" aria-hidden="true">
        <svg viewBox="0 0 64 64" width="28" height="28">
            <!-- Bastion salient: the namesake fortification, also an up-trend. -->
            <path d="M32 5 L59 45 L40 49.5 L32 37 L24 49.5 L5 45 Z" />
        </svg>
    </span>
    <svg class="brand-wordmark" viewBox="0 0 348 80" role="img" aria-label="Ravelin"
         fill="none" stroke="currentColor" stroke-width="9" stroke-linecap="square" stroke-linejoin="miter">
        <path d="M6 8V72 M6 8H44 M44 8V40 M6 40H44 M26 40L50 72 M64 72L88 8L112 72 M73 48H103 M124 8L148 72L172 8 M184 8V72 M184 8H220 M184 40H212 M184 72H220 M232 8V72 M232 72H264 M280 8V72 M296 72V8L332 72V8" />
    </svg>
</a>

@code {
    /// <summary>Link target for the lockup. Defaults to the home page.</summary>
    [Parameter] public string Href { get; set; } = "";
}
