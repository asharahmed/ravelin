@inject AuthService Auth
@inject NavigationManager Nav
@inject HttpClient Http
@inject AuthenticationStateProvider AuthState

<div class="brand-row">
    <Brand Href="" />
    <div class="brand-tag">vulnerability SLA &amp; compliance</div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <AuthorizeView>
            <Authorized>
                <div class="nav-item">
                    <NavLink class="nav-link" href="dashboard">Posture</NavLink>
                </div>
                <div class="nav-item">
                    <NavLink class="nav-link" href="alerts">
                        Alerts
                        @if (alertCount > 0) { <span class="nav-badge">@alertCount</span> }
                    </NavLink>
                </div>
                <div class="nav-item">
                    <NavLink class="nav-link" href="account">Account</NavLink>
                </div>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Roles="@RavelinRoles.Admin">
            <Authorized>
                <div class="nav-item">
                    <NavLink class="nav-link" href="settings/projects">Settings</NavLink>
                </div>
            </Authorized>
        </AuthorizeView>
        <div class="nav-item">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">Home</NavLink>
        </div>
    </nav>

    <div class="nav-foot">
        <AuthorizeView>
            <Authorized>
                <div class="nav-user">
                    <span class="nav-user-label">Signed in</span>
                    <span class="nav-user-name">@context.User.Identity?.Name</span>
                </div>
                <button class="nav-signout" @onclick="LogoutAsync">Sign out</button>
            </Authorized>
            <NotAuthorized>
                <NavLink class="nav-signin" href="login">Sign in</NavLink>
            </NotAuthorized>
        </AuthorizeView>
    </div>
</div>

@code {
    private int alertCount;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        if (auth.User.Identity?.IsAuthenticated != true) return;
        try { alertCount = await Http.GetFromJsonAsync<int>("api/alerts/count"); }
        catch { /* badge stays hidden if the count can't be fetched */ }
    }

    private async Task LogoutAsync()
    {
        await Auth.LogoutAsync();
        Nav.NavigateTo("");
    }
}
