# Copy to .env for `docker compose up`. Change every value before any non-local use.
# .env is gitignored.

# SQL Server 'sa' password. Must meet SQL Server complexity: 8+ chars incl. upper, lower,
# digit, and symbol.
SA_PASSWORD=Ravelin_Local_Dev_1!

# JWT signing key. MUST be at least 32 bytes (the app refuses to start in Production without it).
# Generate one, e.g.:  openssl rand -base64 48
JWT_SIGNING_KEY=change-me-to-a-long-random-value-at-least-32-bytes-long

# Seeded accounts (created on first boot). Passwords must be >= 12 chars.
ADMIN_EMAIL=admin@ravelin.local
ADMIN_PASSWORD=Admin-Local-Pw-1!
DEMO_EMAIL=demo@ravelin.local
DEMO_PASSWORD=Demo-Local-Pw-1!
